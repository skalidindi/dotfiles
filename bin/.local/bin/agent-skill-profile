#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  agent-skill-profile diff [--target TARGET] [PROFILE...]
  agent-skill-profile apply [--target TARGET] [--prune] [PROFILE...]
  agent-skill-profile list [PROFILE...]

Targets:
  shared   ~/.agents/skills
  codex    ~/.codex/skills
  claude   ~/.claude/skills
  cursor   ~/.cursor/skills
  all      shared,codex,claude,cursor

Default profiles are: core netflix
Extras are moved to ~/.agents/disabled-skills/<target>/<timestamp>/ when
--prune is used. They are not deleted.
EOF
}

resolve_script_path() {
  local source="$1"
  local dir
  local link

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    link="$(readlink "$source")"
    case "$link" in
      /*) source="$link" ;;
      *) source="$dir/$link" ;;
    esac
  done

  cd -P "$(dirname "$source")" && pwd
}

count_lines() {
  local file="$1"
  if [ ! -f "$file" ]; then
    printf '0'
    return
  fi
  sed '/^[[:space:]]*$/d' "$file" | wc -l | tr -d ' '
}

write_profile_skills() {
  local output="$1"
  shift

  : >"$output"
  local profile
  local file
  for profile in "$@"; do
    file="$dotfiles_dir/agents/.agents/profiles/${profile}.skills"
    if [ ! -f "$file" ]; then
      printf 'agent-skill-profile: unknown profile: %s\n' "$profile" >&2
      exit 64
    fi
    sed '/^[[:space:]]*$/d; /^[[:space:]]*#/d' "$file" >>"$output"
  done

  sort -u "$output" -o "$output"
}

write_active_skills() {
  local dir="$1"
  local output="$2"

  : >"$output"
  if [ ! -d "$dir" ]; then
    return 0
  fi

  find "$dir" -maxdepth 2 -name SKILL.md -print 2>/dev/null \
    | sed "s#^$dir/##; s#/SKILL.md\$##" \
    | sort -u >"$output"
}

target_dir() {
  case "$1" in
    shared) printf '%s\n' "$HOME/.agents/skills" ;;
    codex) printf '%s\n' "$HOME/.codex/skills" ;;
    claude) printf '%s\n' "$HOME/.claude/skills" ;;
    cursor) printf '%s\n' "$HOME/.cursor/skills" ;;
    *)
      printf 'agent-skill-profile: unknown target: %s\n' "$1" >&2
      exit 64
      ;;
  esac
}

expand_targets() {
  local raw="$1"
  if [ "$raw" = "all" ]; then
    printf '%s\n' shared codex claude cursor
    return 0
  fi

  printf '%s\n' "$raw" | tr ',' '\n' | sed '/^[[:space:]]*$/d'
}

find_skill_source() {
  local skill="$1"
  local candidate

  for candidate in \
    "$HOME/.agents/skills/$skill" \
    "$HOME/.codex/skills/$skill" \
    "$HOME/.claude/skills/$skill" \
    "$HOME/.cursor/skills/$skill"; do
    if [ -f "$candidate/SKILL.md" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if [ -d "$HOME/.agents/disabled-skills" ]; then
    candidate="$(
      find "$HOME/.agents/disabled-skills" -type f -path "*/$skill/SKILL.md" -print 2>/dev/null \
        | sed 's#/SKILL.md$##' \
        | head -n 1
    )"
    if [ -n "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  return 1
}

print_diff() {
  local target="$1"
  local dir="$2"
  local desired="$3"
  local active extras missing

  active="$(mktemp "${TMPDIR:-/tmp}/agent-active.XXXXXXXX")"
  extras="$(mktemp "${TMPDIR:-/tmp}/agent-extras.XXXXXXXX")"
  missing="$(mktemp "${TMPDIR:-/tmp}/agent-missing.XXXXXXXX")"

  write_active_skills "$dir" "$active"
  comm -13 "$desired" "$active" >"$extras"
  comm -23 "$desired" "$active" >"$missing"

  printf '%s: active=%s desired=%s extra=%s missing=%s\n' \
    "$target" \
    "$(count_lines "$active")" \
    "$(count_lines "$desired")" \
    "$(count_lines "$extras")" \
    "$(count_lines "$missing")"

  if [ -s "$missing" ]; then
    sed 's/^/  missing: /' "$missing"
  fi
  if [ -s "$extras" ]; then
    sed 's/^/  extra:   /' "$extras"
  fi

  rm -f "$active" "$extras" "$missing"
}

apply_target() {
  local target="$1"
  local dir="$2"
  local desired="$3"
  local active extras missing stamp backup_dir skill source

  mkdir -p "$dir"

  active="$(mktemp "${TMPDIR:-/tmp}/agent-active.XXXXXXXX")"
  extras="$(mktemp "${TMPDIR:-/tmp}/agent-extras.XXXXXXXX")"
  missing="$(mktemp "${TMPDIR:-/tmp}/agent-missing.XXXXXXXX")"

  write_active_skills "$dir" "$active"
  comm -13 "$desired" "$active" >"$extras"
  comm -23 "$desired" "$active" >"$missing"

  while IFS= read -r skill; do
    [ -n "$skill" ] || continue
    if source="$(find_skill_source "$skill")"; then
      rm -rf "$dir/$skill"
      cp -R "$source" "$dir/$skill"
      printf '%s: installed %s\n' "$target" "$skill"
    else
      printf '%s: missing source for %s\n' "$target" "$skill" >&2
    fi
  done <"$missing"

  if [ "$prune" = "1" ] && [ -s "$extras" ]; then
    stamp="$(date +%Y%m%d-%H%M%S)"
    backup_dir="$HOME/.agents/disabled-skills/$target/$stamp"
    mkdir -p "$backup_dir"

    while IFS= read -r skill; do
      [ -n "$skill" ] || continue
      if [ -d "$dir/$skill" ]; then
        mkdir -p "$(dirname "$backup_dir/$skill")"
        mv "$dir/$skill" "$backup_dir/$skill"
        printf '%s: disabled %s\n' "$target" "$skill"
      fi
    done <"$extras"
  fi

  rm -f "$active" "$extras" "$missing"
}

script_dir="$(resolve_script_path "${BASH_SOURCE[0]}")"
dotfiles_dir="$(cd "$script_dir/../../.." && pwd)"

command="${1:-}"
if [ -z "$command" ]; then
  usage >&2
  exit 64
fi
shift

target_spec="all"
prune=0
profiles=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --target)
      if [ "$#" -lt 2 ]; then
        printf 'agent-skill-profile: --target requires a value\n' >&2
        exit 64
      fi
      target_spec="$2"
      shift 2
      ;;
    --prune)
      prune=1
      shift
      ;;
    -*)
      printf 'agent-skill-profile: unknown option: %s\n' "$1" >&2
      exit 64
      ;;
    *)
      profiles+=("$1")
      shift
      ;;
  esac
done

if [ "${#profiles[@]}" -eq 0 ]; then
  profiles=(core netflix)
fi

desired="$(mktemp "${TMPDIR:-/tmp}/agent-desired.XXXXXXXX")"
trap 'rm -f "$desired"' EXIT
write_profile_skills "$desired" "${profiles[@]}"

case "$command" in
  list)
    cat "$desired"
    ;;
  diff)
    while IFS= read -r target; do
      print_diff "$target" "$(target_dir "$target")" "$desired"
    done < <(expand_targets "$target_spec")
    ;;
  apply)
    while IFS= read -r target; do
      apply_target "$target" "$(target_dir "$target")" "$desired"
    done < <(expand_targets "$target_spec")
    ;;
  *)
    printf 'agent-skill-profile: unknown command: %s\n' "$command" >&2
    usage >&2
    exit 64
    ;;
esac
