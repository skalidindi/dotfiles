#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local source="$1"
  local dir
  local link

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    link="$(readlink "$source")"
    case "$link" in
      /*) source="$link" ;;
      *) source="$dir/$link" ;;
    esac
  done

  dir="$(cd -P "$(dirname "$source")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$source")"
}

self="$(resolve_path "${BASH_SOURCE[0]}")"
real_command=""

while IFS= read -r candidate; do
  [ -n "$candidate" ] || continue
  if [ "$(resolve_path "$candidate")" != "$self" ]; then
    real_command="$candidate"
    break
  fi
done < <(type -a -p claude 2>/dev/null || true)

if [ -z "$real_command" ]; then
  printf 'claude wrapper: could not find real claude binary on PATH\n' >&2
  exit 69
fi

exec zrun "$real_command" "$@"
