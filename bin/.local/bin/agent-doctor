#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source="$1"
  local dir
  local link

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    link="$(readlink "$source")"
    case "$link" in
      /*) source="$link" ;;
      *) source="$dir/$link" ;;
    esac
  done

  cd -P "$(dirname "$source")" && pwd
}

count_files() {
  local dir="$1"
  local pattern="$2"

  if [ ! -d "$dir" ]; then
    printf '0'
    return
  fi

  find "$dir" -name "$pattern" -type f 2>/dev/null | wc -l | tr -d ' '
}

count_grep() {
  local file="$1"
  local pattern="$2"

  if [ ! -f "$file" ]; then
    printf '0'
    return
  fi

  grep -E "$pattern" "$file" 2>/dev/null | wc -l | tr -d ' '
}

status_path() {
  local path="$1"
  local label="$2"
  local resolved_dir
  local resolved_path

  if [ -L "$path" ]; then
    printf 'ok    %-28s symlink -> %s\n' "$label" "$(readlink "$path")"
  elif [ -e "$path" ]; then
    resolved_dir="$(cd -P "$(dirname "$path")" 2>/dev/null && pwd || true)"
    resolved_path="$resolved_dir/$(basename "$path")"
    case "$resolved_path" in
      "$dotfiles_dir"/*)
        printf 'ok    %-28s managed in dotfiles\n' "$label"
        ;;
      *)
        printf 'warn  %-28s exists but is not managed by dotfiles\n' "$label"
        ;;
    esac
  else
    printf 'miss  %-28s not found\n' "$label"
  fi
}

status_command() {
  local name="$1"

  if command -v "$name" >/dev/null 2>&1; then
    printf 'ok    %-28s %s\n' "$name" "$(command -v "$name")"
  else
    printf 'miss  %-28s not on PATH\n' "$name"
  fi
}

status_same_file() {
  local expected="$1"
  local actual="$2"
  local label="$3"

  if [ ! -f "$expected" ]; then
    printf 'miss  %-28s expected file missing\n' "$label"
  elif [ ! -f "$actual" ]; then
    printf 'miss  %-28s target file missing\n' "$label"
  elif cmp -s "$expected" "$actual"; then
    printf 'ok    %-28s in sync\n' "$label"
  else
    printf 'warn  %-28s differs from shared base\n' "$label"
  fi
}

script_dir="$(resolve_script_path "${BASH_SOURCE[0]}")"
dotfiles_dir="$(cd "$script_dir/../../.." && pwd)"

printf 'agent-doctor\n'
printf '%s\n\n' '============'

printf 'dotfiles: %s\n' "$dotfiles_dir"
if git -C "$dotfiles_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  printf 'branch:   %s\n' "$(git -c core.fsmonitor=false -C "$dotfiles_dir" branch --show-current 2>/dev/null || printf 'unknown')"
  if [ -n "$(git -c core.fsmonitor=false -C "$dotfiles_dir" status --porcelain 2>/dev/null)" ]; then
    printf 'status:   dirty\n'
  else
    printf 'status:   clean\n'
  fi
else
  printf 'branch:   not a git worktree\n'
fi

printf '\nStowed surfaces\n'
printf '%s\n' '---------------'
status_path "$HOME/.agents" "shared agents"
status_path "$HOME/.agents/README.md" "shared agents readme"
status_path "$HOME/.codex/AGENTS.md" "codex prompt"
status_path "$HOME/.claude/CLAUDE.md" "claude prompt"
status_path "$HOME/.pi/agent/keybindings.json" "pi keybindings"
status_path "$HOME/.pi/agent/settings.json.tpl" "pi settings template"

printf '\nPrompt sync\n'
printf '%s\n' '-----------'
status_same_file "$dotfiles_dir/agents/.agents/prompts/base.md" "$dotfiles_dir/claude/.claude/CLAUDE.md" "claude prompt"
status_same_file "$dotfiles_dir/agents/.agents/prompts/base.md" "$dotfiles_dir/codex/.codex/AGENTS.md" "codex prompt"

printf '\nCommands\n'
printf '%s\n' '--------'
for cmd in zrun agent-awake codex claude pi; do
  status_command "$cmd"
done

printf '\nSkill counts\n'
printf '%s\n' '------------'
printf 'codex:  %s\n' "$(count_files "$HOME/.codex/skills" 'SKILL.md')"
printf 'claude: %s\n' "$(count_files "$HOME/.claude/skills" 'SKILL.md')"
printf 'cursor: %s\n' "$(count_files "$HOME/.cursor/skills" 'SKILL.md')"
printf 'pi:     %s\n' "$(count_files "$HOME/.pi/agent/skills" 'SKILL.md')"

printf '\nMCP counts\n'
printf '%s\n' '----------'
printf 'codex:  %s\n' "$(count_grep "$HOME/.codex/config.toml" '^\[mcp_servers\.')"
if command -v jq >/dev/null 2>&1 && [ -f "$HOME/.cursor/mcp.json" ]; then
  printf 'cursor: %s\n' "$(jq '.mcpServers | length' "$HOME/.cursor/mcp.json" 2>/dev/null || printf '0')"
else
  printf 'cursor: %s\n' "$(count_grep "$HOME/.cursor/mcp.json" '^[[:space:]]*"[^"]+"[[:space:]]*:[[:space:]]*\{')"
fi
if command -v jq >/dev/null 2>&1 && [ -f "$HOME/.pi/agent/mcp.json" ]; then
  printf 'pi:     %s\n' "$(jq '.mcpServers | length' "$HOME/.pi/agent/mcp.json" 2>/dev/null || printf '0')"
else
  printf 'pi:     %s\n' "$(count_grep "$HOME/.pi/agent/mcp.json" '^[[:space:]]*"[^"]+"[[:space:]]*:[[:space:]]*\{')"
fi

printf '\nRuntime state check\n'
printf '%s\n' '-------------------'
for path in \
  "$HOME/.codex/auth.json" \
  "$HOME/.codex/google_credentials.json" \
  "$HOME/.claude/client_secrets.json" \
  "$HOME/.cursor/client_secrets.json" \
  "$HOME/.pi/agent/auth.json"; do
  if [ -e "$path" ]; then
    printf 'local %-28s present, should not be committed\n' "${path#$HOME/}"
  fi
done

printf '\nNext checks\n'
printf '%s\n' '-----------'
printf 'Run this after bootstrap or stow changes. Warnings are not failures; they mark drift to classify.\n'
