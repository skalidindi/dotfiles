#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  zrun [--name SESSION | --name-prefix PREFIX] [--] COMMAND [ARGS...]
  zrun --list
  zrun --attach [SESSION]

Run COMMAND inside a new zellij session. If already inside zellij, COMMAND is
executed directly.
EOF
}

require_zellij() {
  if ! command -v zellij >/dev/null 2>&1; then
    printf 'zrun: zellij is not installed or not on PATH\n' >&2
    exit 69
  fi
}

sanitize_session_name() {
  local value
  value="$(printf '%s' "$1" | LC_ALL=C tr -c '[:alnum:]._-' '-' | sed 's/^-*//; s/-*$//; s/--*/-/g')"
  printf '%s' "${value:-agent}"
}

truncate_string() {
  local value="$1"
  local max_length="$2"

  printf '%s' "${value:0:max_length}"
}

build_default_session_name() {
  local base cwd_name timestamp available

  base="$(sanitize_session_name "${session_prefix:-$original_command_name}")"
  cwd_name="$(sanitize_session_name "$(basename "$PWD")")"
  timestamp="$(date +%H%M%S)"

  available=$((session_name_limit - ${#base} - ${#timestamp} - 2))
  if [ "$available" -lt 1 ]; then
    base="$(truncate_string "$base" $((session_name_limit - ${#timestamp} - 2)))"
    available=1
  fi

  cwd_name="$(truncate_string "$cwd_name" "$available")"
  printf '%s-%s-%s' "$base" "$cwd_name" "$timestamp"
}

kdl_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

session_name_limit=24
session_name=""
session_prefix=""
session_name_is_explicit=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --list)
      shift
      require_zellij
      exec zellij list-sessions "$@"
      ;;
    --attach)
      shift
      require_zellij
      exec zellij attach "$@"
      ;;
    -n|--name|--session)
      if [ "$#" -lt 2 ]; then
        printf 'zrun: %s requires a value\n' "$1" >&2
        exit 64
      fi
      session_name="$2"
      session_name_is_explicit=1
      shift 2
      ;;
    --name-prefix|--prefix)
      if [ "$#" -lt 2 ]; then
        printf 'zrun: %s requires a value\n' "$1" >&2
        exit 64
      fi
      session_prefix="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'zrun: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 64
      ;;
    *)
      break
      ;;
  esac
done

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 64
fi

original_command_name="$(basename "$1")"

if [ ! -t 0 ] || [ ! -t 1 ]; then
  exec "$@"
fi

if [ -n "${ZELLIJ:-}" ]; then
  exec "$@"
fi

require_zellij

if [ -z "$session_name" ]; then
  session_name="$(build_default_session_name)"
fi

session_name="$(sanitize_session_name "$session_name")"
if [ "${#session_name}" -gt "$session_name_limit" ]; then
  if [ "$session_name_is_explicit" -eq 1 ]; then
    printf 'zrun: session name must be %s characters or fewer: %s\n' "$session_name_limit" "$session_name" >&2
    exit 64
  fi

  session_name="$(truncate_string "$session_name" "$session_name_limit")"
fi

launcher="$(mktemp "${TMPDIR:-/tmp}/zrun.XXXXXXXX")"
layout_file="$(mktemp "${TMPDIR:-/tmp}/zrun-layout.XXXXXXXX")"
trap 'rm -f -- "$launcher" "$layout_file"' EXIT

{
  printf '#!/usr/bin/env bash\n'
  printf 'set -euo pipefail\n'
  printf 'rm -f -- %q %q\n' "$launcher" "$layout_file"
  printf 'cd -- %q\n' "$PWD"
  printf 'exec'
  printf ' %q' "$@"
  printf '\n'
} >"$launcher"
chmod 700 "$launcher"

{
  printf 'layout {\n'
  printf '    pane command="zsh" {\n'
  printf '        args "-lc" "exec %s"\n' "$(kdl_escape "$(printf '%q' "$launcher")")"
  printf '    }\n'
  printf '}\n'
} >"$layout_file"

zellij --new-session-with-layout "$layout_file" --session "$session_name"
